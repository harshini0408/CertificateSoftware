# ══════════════════════════════════════
# PSG iTech Certificate Platform — .env
# ══════════════════════════════════════

# ── App ──────────────────────────────
APP_ENV=development
SECRET_KEY=replace-with-random-64-char-hex-string
ALGORITHM=HS256
FRONTEND_URL=http://localhost:5179
BASE_URL=https://certs.psgit.edu

# ── MongoDB ──────────────────────────
MONGODB_URL=mongodb://certsoftware:<db_password>@ac-ko16dle-shard-00-00.yacwq8u.mongodb.net:27017,ac-ko16dle-shard-00-01.yacwq8u.mongodb.net:27017,ac-ko16dle-shard-00-02.yacwq8u.mongodb.net:27017/?replicaSet=atlas-5n6kut-shard-0&ssl=true&authSource=admin
DB_NAME=certsoftware

# ── JWT ──────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Storage ──────────────────────────
STORAGE_PATH=./storage

# ── Gmail OAuth2 ─────────────────────
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json
GMAIL_SENDER_EMAIL=certs@psgit.edu
EMAIL_DAILY_LIMIT=500

# ── Super Admin Seed ─────────────────
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-on-first-run
SUPERADMIN_EMAIL=admin@psgit.edu
SUPERADMIN_NAME=Platform Admin
